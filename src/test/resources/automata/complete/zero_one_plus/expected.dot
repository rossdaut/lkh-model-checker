digraph {
    init_ [shape = "point"];
    init_ -> 0;
    2 [shape = "doublecircle"];

    0 -> 1 [label = "0"];
    0 -> error [label = "1"];
    1 -> 2 [label = "1"];
    1 -> error [label = "0"];
    2 -> 2 [label = "1"];
    2 -> error [label = "0"];
    error -> error [label = "0"];
    error -> error [label = "1"]
}
