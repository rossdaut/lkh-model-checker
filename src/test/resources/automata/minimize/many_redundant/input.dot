digraph {
    init_ [shape = "point"];
    init_ -> 0;

    1 [shape = "doublecircle"];
    2 [shape = "doublecircle"];
    3 [shape = "doublecircle"];
    4 [shape = "doublecircle"];

    0 -> 1 [label = "a"];
    0 -> 5 [label = "b"];
    1 -> 2 [label = "a"];
    1 -> 3 [label = "b"];
    2 -> 2 [label = "a"];
    2 -> 3 [label = "b"];
    3 -> 4 [label = "a"];
    3 -> 4 [label = "b"];
    4 -> 4 [label = "a"];
    4 -> 4 [label = "b"];
    5 -> 5 [label = "a"];
    5 -> 5 [label = "b"]
}
